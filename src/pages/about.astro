---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="About Us" description="About Overstudied and its author, Armaandeep Singh.">
  <main id="main-content" class="page-shell about-page">
    <header class="page-intro section-intro">
      <p class="page-kicker">About us</p>
      <h1>Technical writing for people who want to understand deeply.</h1>
      <p>Overstudied turns difficult engineering subjects into focused notes, system explanations, and practical study paths.</p>
    </header>

    <div class="about-sections">
      <section>
        <h2>About Overstudied</h2>
        <p>
          Overstudied is a minimal technical publication covering algorithms, backend systems,
          data platforms, machine learning operations, generative AI, and system architecture.
          The goal is useful understanding without noise or unnecessary product framing.
        </p>
      </section>

      <section>
        <p class="page-kicker">Author details</p>
        <h2>Armaandeep Singh</h2>
        <p>
          Software developer with experience in machine learning, MLOps, Databricks, and
          generative AI.
        </p>
        <a class="text-link" href="https://in.linkedin.com/in/armaanaura" target="_blank" rel="noreferrer">
          Connect with Armaandeep on LinkedIn
          <span class="visually-hidden"> (opens in a new tab)</span>
        </a>
      </section>
    </div>
  </main>
</BaseLayout>
