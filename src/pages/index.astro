---
import ArchitectureRow from "../components/ArchitectureRow.astro";
import ArticleRow from "../components/ArticleRow.astro";
import DomainCard from "../components/DomainCard.astro";
import SearchBox from "../components/SearchBox.astro";
import TopicTabs from "../components/TopicTabs.astro";
import { architectures } from "../data/architectures";
import { articles } from "../data/articles";
import { domains } from "../data/domains";
import homepageImage from "../Assets/homepage.png";
import BaseLayout from "../layouts/BaseLayout.astro";

const tabs = [
  { label: "Latest", value: "latest" },
  { label: "Articles", value: "article" },
  { label: "Architectures", value: "architecture" },
  { label: "Study Domains", value: "domain" },
];

const latest = [
  ...articles.map((item) => ({ date: item.date, kind: "article" as const, item })),
  ...architectures.map((item) => ({ date: item.date, kind: "architecture" as const, item })),
  ...domains.map((item) => ({ date: item.lastUpdated, kind: "domain" as const, item })),
].sort((a, b) => b.date.localeCompare(a.date));
---

<BaseLayout
  title="Overstudied"
  description="Deep technical notes, architecture explainers, and focused study domains."
>
  <main id="main-content" class="home-page">
    <div class="home-hero__media">
      <img
        src={homepageImage.src}
        width={homepageImage.width}
        height={homepageImage.height}
        alt="Sketch of notebooks, technical diagrams, charts, and writing tools"
        loading="eager"
        decoding="async"
        fetchpriority="high"
      />
      <div class="home-hero__copy">
        <h1>Become disgustingly over educated</h1>
        <p>
          Study the ideas everyone skips, connect them across systems, and build understanding that compounds.
        </p>
        <div class="home-hero__actions" aria-label="Explore Overstudied content">
          <a class="home-hero__button home-hero__button--primary" href="/domains">Explore Domains</a>
          <a class="home-hero__button home-hero__button--secondary" href="/articles">Articles</a>
        </div>
      </div>
    </div>

    <div class="page-shell home-page__content">
      <div class="page-search">
        <SearchBox id="content-search" placeholder="Search articles" />
      </div>

      <TopicTabs items={tabs} current="latest" interactive />

      <section class="mixed-feed" aria-label="Latest Overstudied content">
        {latest.map((entry) => {
          if (entry.kind === "article") return <ArticleRow article={entry.item} />;
          if (entry.kind === "architecture") return <ArchitectureRow architecture={entry.item} />;
          return <div class="domain-feed-entry"><DomainCard domain={entry.item} /></div>;
        })}
        <p class="empty-state" data-search-empty hidden>No content matches this search.</p>
      </section>
    </div>
  </main>
</BaseLayout>
